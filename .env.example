# Database (PostgreSQL / Neon)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/residence_sas

# JWT
SECRET_KEY=super-secret-change-me-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (comma separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# App
APP_NAME=Residence SaaS API
APP_VERSION=1.0.0
DEBUG=true

# SMTP (Email – para PINs de autenticación)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TLS=true
PIN_EXPIRE_MINUTES=10

# Gemini AI (RAG chatbot)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004
